# Entorno — contiene credenciales
.env

# Generado en runtime desde application.properties.template
conf/application.properties

# Reportes en runtime — versionar solo la carpeta, no el contenido
reports/*
!reports/.gitkeep

# Logs del contenedor montados como volumen
logs/

# Notas locales de sesión — no versionar
.notes/

# macOS
.DS_Store
