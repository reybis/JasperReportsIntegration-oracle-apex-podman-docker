# ============================================================
# JasperReportsIntegration — Variables de entorno
# Copiar a .env y ajustar según el ambiente
# ============================================================

# ── Oracle Database ──────────────────────────────────────────
# Nombre del contenedor Oracle (usado por podman exec en init-db.sh)
ORACLE_CONTAINER=my-oracle-container

# Hostname de Oracle dentro de la red Podman (normalmente igual al container name)
ORACLE_HOST=my-oracle-container

# Puerto interno de Oracle dentro de la red (no el del host)
ORACLE_PORT=1521

# Nombre del PDB / servicio
ORACLE_SERVICE=FREEPDB1

# Password de SYS (necesario para sys_install.sql y ACL)
ORACLE_SYS_PWD=changeme

# Schema de la aplicación donde se instalan los objetos PL/SQL
ORACLE_APP_SCHEMA=my_schema

# Password del schema de la aplicación
ORACLE_APP_PWD=changeme

# ── JasperReportsIntegration ─────────────────────────────────
# Versión de JRI (usada en build y en init-db.sh)
JRI_VERSION=3.0.0

# Versión de JasperReports empaquetada en el artefacto
JRI_JASPER=7.0.1

# Nombre del contenedor JRI (usado también en la ACL de red de Oracle)
JRI_CONTAINER=jri

# Puerto expuesto en el host
JRI_HOST_PORT=8090

# ── Red Podman ───────────────────────────────────────────────
# Nombre exacto de la red Podman compartida con Oracle
PODMAN_NETWORK=my-podman-network
